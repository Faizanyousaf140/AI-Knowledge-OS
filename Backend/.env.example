# Core
NODE_ENV=production
PORT=5000
MONGO_URI=llocalhost:27017/ai-knowledge-os

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=

# API URLs
API_BASE=https://your-backend.up.railway.app
FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGIN=https://your-app.vercel.app

# Email (SMTP)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=

# AI providers (use what your app is configured for)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Optional compatibility key if you later use OpenAI code paths
OPENAI_API_KEY=

# Optional embeddings/queue
EMBEDDING_QUEUE_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
